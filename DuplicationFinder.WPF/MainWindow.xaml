<Window x:Class="DuplicationFinder.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DuplicationFinder.WPF.ViewModels"
        xmlns:conv="clr-namespace:DuplicationFinder.WPF.Converters"
        Title="DuplicationFinder"
        Height="720" Width="1080"
        MinHeight="600" MinWidth="800"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:FileSizeConverter x:Key="FileSizeConverter"/>
        <conv:BoolToOriginalLabelConverter x:Key="OriginalLabelConverter"/>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ HEADER ═══════════ -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="32,24">
            <StackPanel>
                <TextBlock FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                    <Run Text="🔍"/>
                    <Run Text=" DuplicationFinder"/>
                </TextBlock>
                <TextBlock Text="Find and manage duplicate files across your folders"
                           FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══════════ FOLDER PICKER ═══════════ -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                Margin="24,16,24,0" Padding="24" CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <!-- Folder Path Input -->
                    <TextBlock Text="Target Folder"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding SelectedFolderPath, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True" Margin="0,0,12,0"/>

                        <Button Grid.Column="1"
                                Content="📂  Browse"
                                Command="{Binding BrowseFolderCommand}"
                                Style="{StaticResource SecondaryButton}"/>
                    </Grid>

                    <!-- Options Row -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <CheckBox Content="Recursive (include subfolders)"
                                  IsChecked="{Binding IsRecursive}" Margin="0,0,32,0"/>
                        <CheckBox Content="Dry Run (no files will be deleted)"
                                  IsChecked="{Binding IsDryRun}" Margin="0,0,0,0">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDryRun}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>
                    </StackPanel>
                </StackPanel>

                <!-- Start Scan Button Big -->
                <Button Grid.Column="1"
                        Content="🚀  Start Scan"
                        Command="{Binding ScanCommand}"
                        Style="{StaticResource PrimaryButton}"
                        VerticalAlignment="Bottom"
                        Padding="40,16"
                        Margin="32,0,0,0"/>
            </Grid>
        </Border>

        <!-- ═══════════ STATS BAR ═══════════ -->
        <Border Grid.Row="2" Margin="24,12,24,0" Padding="20,16" CornerRadius="12"
                Background="{StaticResource SurfaceBrush}"
                Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Stat: Unique Duplicates -->
                <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="8"
                        Padding="24,12" Margin="0,0,12,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding UniqueDuplicateCount}" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Duplicate Groups" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Stat: Total Redundant -->
                <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="8"
                        Padding="24,12" Margin="0,0,12,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalRedundantCopies}" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Redundant Copies" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Stat: Max Redundancy -->
                <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="8"
                        Padding="24,12">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding MaxRedundancy}" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Max Redundancy" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══════════ RESULTS LIST ═══════════ -->
        <Border Grid.Row="3" Margin="24,12,24,0" CornerRadius="12"
                Background="{StaticResource SurfaceBrush}">
            <Grid>
                <!-- Scanning Indicator -->
                <StackPanel Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressValue}"
                                 Width="300" Height="6"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 Background="{StaticResource SurfaceLightBrush}" BorderThickness="0"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0">
                        <Run Text="Scanning: "/>
                        <Run Text="{Binding CurrentScanningFile}" FontWeight="SemiBold"/>
                        <Run Text=" ("/>
                        <Run Text="{Binding ProgressText}"/>
                        <Run Text=")"/>
                    </TextBlock>
                </StackPanel>

                <!-- Results -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <ItemsControl ItemsSource="{Binding DuplicateGroups}" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceLightBrush}"
                                        CornerRadius="10" Margin="0,0,0,12" Padding="20">
                                    <StackPanel>
                                        <!-- Group Header -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock FontSize="15" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}">
                                                    <Run Text="Group #"/>
                                                    <Run Text="{Binding GroupNumber, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="12" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="16,0,0,0">
                                                    <Run Text="Hash: "/>
                                                    <Run Text="{Binding FileHash, Mode=OneWay}"
                                                         FontFamily="Consolas"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="✓ All"
                                                        Command="{Binding SelectAllCommand}"
                                                        Style="{StaticResource TextButton}"
                                                        Margin="0,0,8,0" Padding="8,2"/>
                                                <Button Content="✕ None"
                                                        Command="{Binding DeselectAllCommand}"
                                                        Style="{StaticResource TextButton}"
                                                        Margin="0,0,16,0" Padding="8,2"/>

                                                <Border Background="{StaticResource SurfaceBrush}"
                                                        CornerRadius="6" Padding="12,4">
                                                    <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}">
                                                        <Run Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}, Mode=OneWay}"/>
                                                        <Run Text=" each"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Separator -->
                                        <Border Height="1" Background="{StaticResource BorderBrush}"
                                                Margin="0,0,0,10"/>

                                        <!-- File List -->
                                        <ItemsControl ItemsSource="{Binding Files}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,2" Padding="12,10" CornerRadius="8" BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOriginal}" Value="True">
                                                                        <Setter Property="Background" Value="#08FFFFFF"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="#1A00D9A6"/>
                                                                        <Setter Property="BorderBrush" Value="#4000D9A6"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#10FFFFFF"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
 
                                                            <CheckBox Grid.Column="0"
                                                                      IsChecked="{Binding IsSelected}"
                                                                      IsEnabled="{Binding IsOriginal, Converter={StaticResource InverseBoolConverter}}"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,16,0"/>
 
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock FontSize="13" FontWeight="Medium"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           Text="{Binding FileName}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           Text="{Binding Directory}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Opacity="0.7"/>
                                                            </StackPanel>
 
                                                            <Border Grid.Column="2" VerticalAlignment="Center"
                                                                    Visibility="{Binding IsOriginal, Converter={StaticResource BoolToVisibility}}"
                                                                    Background="#2000D9A6" CornerRadius="4" Padding="8,2">
                                                                <TextBlock Text="★ ORIGINAL" FontSize="10" FontWeight="Bold"
                                                                           Foreground="{StaticResource AccentBrush}"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══════════ ACTION BAR & STATUS ═══════════ -->
        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" Padding="24,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    
                    <!-- Dry Run Badge -->
                    <Border Visibility="{Binding IsDryRun, Converter={StaticResource BoolToVisibility}}"
                            Background="#20FFD93D" BorderBrush="{StaticResource WarningBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="16,0,0,0">
                        <TextBlock Text="🧪 DRY RUN ACTIVE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                    </Border>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="🗑  Remove Selected Duplicates"
                        Command="{Binding DeleteSelectedCommand}"
                        Style="{StaticResource DangerButton}"
                        Padding="24,10"
                        Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
